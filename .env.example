# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — SERVER ONLY, never expose to client
# Required for: admin API routes, Stripe webhook, stripe-config.ts
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── External APIs ────────────────────────────────────────────────────────────
# brapi.dev — Brazilian market data (free tier: prices + dividends)
NEXT_PUBLIC_BRAPI_TOKEN=your-brapi-token-here

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://invest.sinedtech.com
NEXT_PUBLIC_APP_NAME=SINED Invest

# ─── Stripe — TEST environment ────────────────────────────────────────────────
# Get these from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY_TEST=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY_TEST=pk_test_...
STRIPE_WEBHOOK_SECRET_TEST=whsec_...
STRIPE_PRICE_SIMPLE_TEST=price_...
STRIPE_PRICE_ADVANCED_TEST=price_...

# ─── Stripe — LIVE environment ────────────────────────────────────────────────
# Get these from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY_LIVE=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY_LIVE=pk_live_...
STRIPE_WEBHOOK_SECRET_LIVE=whsec_...
STRIPE_PRICE_SIMPLE_LIVE=price_...
STRIPE_PRICE_ADVANCED_LIVE=price_...

# ─── Active mode is controlled from Admin → Settings → Stripe Mode ─────────────
# Do NOT add a STRIPE_MODE env var here — it is stored in the app_config
# database table and toggled from the Admin Panel UI, not from env vars.
